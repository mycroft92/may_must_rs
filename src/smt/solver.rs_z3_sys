    }

    #[test]
    fn test_multiple_contexts() {
        let mut ctx1 = Z3Context::new();
        let mut ctx2 = Z3Context::new();

        ctx1.mk_int_var("x");
        ctx2.mk_int_var("x");

        assert!(ctx1.get_var("x").is_some());
        assert!(ctx2.get_var("x").is_some());
    }

    #[test]
    fn test_fresh_name_generation() {
        let mut ctx = Z3Context::new();

        let (name1, _) = ctx.mk_fresh_int_var("var");
        let (name2, _) = ctx.mk_fresh_int_var("var");
        let (name3, _) = ctx.mk_fresh_int_var("var");

        assert_eq!(name1, "var_0");
        assert_eq!(name2, "var_1");
        assert_eq!(name3, "var_2");
    }

    #[test]
    fn test_constants() {
        let ctx = Z3Context::new();

        let _true_ast = ctx.mk_true();
        let _false_ast = ctx.mk_false();
    }

    #[test]
    fn test_recursive_function_definition() {
        let mut ctx = Z3Context::new();

        // Create recursive factorial function: factorial(n) = if n <= 0 then 1 else n * factorial(n-1)
        let int_sort = ctx.int_sort();
        let domain = vec![int_sort];
        let factorial = ctx.mk_rec_func_decl("factorial", &domain, int_sort);

        // Create the parameter variable
        let n = ctx.mk_int_var("n");
        let n_ast = n.as_ast();

        // Create constants
        let zero = unsafe {
            let ast = Z3_mk_int(ctx.raw_context(), 0, int_sort);
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        let one = unsafe {
            let ast = Z3_mk_int(ctx.raw_context(), 1, int_sort);
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Create n <= 0
        let n_le_zero = unsafe {
            let ast = Z3_mk_le(ctx.raw_context(), n_ast, zero);
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Create n - 1
        let n_minus_1 = unsafe {
            let ast = Z3_mk_sub(ctx.raw_context(), 2, [n_ast, one].as_ptr());
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Create factorial(n-1)
        let factorial_n_minus_1 = ctx.mk_app(factorial, &[n_minus_1]);

        // Create n * factorial(n-1)
        let n_times_factorial = unsafe {
            let ast = Z3_mk_mul(ctx.raw_context(), 2, [n_ast, factorial_n_minus_1].as_ptr());
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Create if-then-else: if n <= 0 then 1 else n * factorial(n-1)
        let body = unsafe {
            let ast = Z3_mk_ite(ctx.raw_context(), n_le_zero, one, n_times_factorial);
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Add the recursive definition
        ctx.add_rec_def(factorial, &[n_ast], body);

        // Verify the function was created
        assert!(ctx.get_func("factorial").is_some());

        // Clean up
        unsafe {
            Z3_dec_ref(ctx.raw_context(), zero);
            Z3_dec_ref(ctx.raw_context(), one);
            Z3_dec_ref(ctx.raw_context(), n_le_zero);
            Z3_dec_ref(ctx.raw_context(), n_minus_1);
            Z3_dec_ref(ctx.raw_context(), factorial_n_minus_1);
            Z3_dec_ref(ctx.raw_context(), n_times_factorial);
            Z3_dec_ref(ctx.raw_context(), body);
        }
    }

    #[test]
    fn test_recursive_fibonacci() {
        let mut ctx = Z3Context::new();

        // Create recursive fibonacci function: fib(n) = if n <= 1 then n else fib(n-1) + fib(n-2)
        let int_sort = ctx.int_sort();
        let domain = vec![int_sort];
        let fib = ctx.mk_rec_func_decl("fib", &domain, int_sort);

        // Create the parameter variable
        let n = ctx.mk_int_var("n");
        let n_ast = n.as_ast();

        // Create constants
        let one = unsafe {
            let ast = Z3_mk_int(ctx.raw_context(), 1, int_sort);
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        let two = unsafe {
            let ast = Z3_mk_int(ctx.raw_context(), 2, int_sort);
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Create n <= 1
        let n_le_one = unsafe {
            let ast = Z3_mk_le(ctx.raw_context(), n_ast, one);
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Create n - 1
        let n_minus_1 = unsafe {
            let ast = Z3_mk_sub(ctx.raw_context(), 2, [n_ast, one].as_ptr());
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Create n - 2
        let n_minus_2 = unsafe {
            let ast = Z3_mk_sub(ctx.raw_context(), 2, [n_ast, two].as_ptr());
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Create fib(n-1)
        let fib_n_minus_1 = ctx.mk_app(fib, &[n_minus_1]);

        // Create fib(n-2)
        let fib_n_minus_2 = ctx.mk_app(fib, &[n_minus_2]);

        // Create fib(n-1) + fib(n-2)
        let fib_sum = unsafe {
            let ast = Z3_mk_add(
                ctx.raw_context(),
                2,
                [fib_n_minus_1, fib_n_minus_2].as_ptr(),
            );
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Create if-then-else: if n <= 1 then n else fib(n-1) + fib(n-2)
        let body = unsafe {
            let ast = Z3_mk_ite(ctx.raw_context(), n_le_one, n_ast, fib_sum);
            Z3_inc_ref(ctx.raw_context(), ast);
            ast
        };

        // Add the recursive definition
        ctx.add_rec_def(fib, &[n_ast], body);

        // Verify the function was created
        assert!(ctx.get_func("fib").is_some());

        // Clean up
        unsafe {
            Z3_dec_ref(ctx.raw_context(), one);
            Z3_dec_ref(ctx.raw_context(), two);
            Z3_dec_ref(ctx.raw_context(), n_le_one);
            Z3_dec_ref(ctx.raw_context(), n_minus_1);
            Z3_dec_ref(ctx.raw_context(), n_minus_2);
            Z3_dec_ref(ctx.raw_context(), fib_n_minus_1);
            Z3_dec_ref(ctx.raw_context(), fib_n_minus_2);
            Z3_dec_ref(ctx.raw_context(), fib_sum);
            Z3_dec_ref(ctx.raw_context(), body);
        }
    }
}
